{
  "name": "vibe-audit",
  "version": "1.0.0",
  "description": "Security audit CLI for AI-generated codebases. Find the time bombs before they blow.",
  "type": "module",
  "engines": {
    "node": ">=18.3.0"
  },
  "bin": {
    "vibe-audit": "./bin/vibe-audit.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "bin/",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "node --test tests/**/*.test.js tests/**/**/*.test.js",
    "lint": "eslint src/ bin/ tests/",
    "audit:self": "node bin/vibe-audit.js .",
    "prepublishOnly": "npm test && npm run lint"
  },
  "keywords": [
    "security",
    "audit",
    "vibe-coding",
    "ai-generated-code",
    "cli",
    "static-analysis",
    "devsecops",
    "ast"
  ],
  "author": "Digital Alchemy Academy <hello@digitalalchemy.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jackdog668/vibeaudit"
  },
  "homepage": "https://digitalalchemy.dev/vibe-audit",
  "dependencies": {
    "acorn": "^8.16.0",
    "acorn-loose": "^8.5.2"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  }
}
